# Servidor
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Base de datos (PostgreSQL)
# Local: PostgreSQL local | Producción: Render PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=cbtomelloso_user
DB_PASSWORD=contraseña
DB_NAME=cbtomelloso
DB_SYNC=true
DB_LOGGING=true
# SSL (solo producción con Render)
DB_SSL=false

# JWT
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=tu_refresh_secret_aqui
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# URL base (para construir URLs absolutas de media proxy)
BASE_URL=http://localhost:3000

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Instagram Graph API (cuenta de creador @cbtomelloso)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
