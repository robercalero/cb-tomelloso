# Servidor
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Base de datos (MySQL / Aiven)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=usuario
DB_PASSWORD=contraseña
DB_NAME=cbtomelloso
DB_SYNC=true
DB_LOGGING=true
# SSL (producción con Aiven: DISABLED o REQUIRED)
DB_SSL=DISABLED
# Ruta al certificado CA de Aiven (solo si DB_SSL=REQUIRED)
DB_CA_CERT=

# JWT
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=tu_refresh_secret_aqui
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# URL base (para construir URLs absolutas de media proxy)
BASE_URL=http://localhost:3000

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Instagram Graph API (cuenta de creador @cbtomelloso)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
