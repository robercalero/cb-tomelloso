# Servidor
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Base de datos (MariaDB local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_NAME=cbtomelloso
DB_SSL=DISABLED

# JWT
# Generar secretos con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# URL base (para construir URLs absolutas de media proxy)
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Stripe (poner claves reales en Render dashboard, no aquí)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PUBLIC_KEY=pk_test_placeholder

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@cbtomelloso.es
ADMIN_EMAIL=admin@cbtomelloso.es
